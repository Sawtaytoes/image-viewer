{
  "name": "ImageViewer",
  "productName": "Image Viewer",
  "description": "A simple tool for browsing and viewing images.",
  "author": "Kevin Ghadyani",
  "version": "2.0.0",
  "private": true,
  "license": "MIT",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "start:fake": "IMAGE_VIEWER_FAKE_FS=1 electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint:biome": "biome check",
    "lint:biome-format": "biome check --write",
    "lint:eslint": "eslint .",
    "lint:eslint-format": "eslint . --fix",
    "lint": "yarn lint:biome-format && yarn lint:eslint-format"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "electron-squirrel-startup": "^1.0.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rxjs": "^7.8.2",
    "string-natural-compare": "^3.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/shared-types": "^7.11.2",
    "@electron/fuses": "^2.1.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "yarn@4.16.0"
}
