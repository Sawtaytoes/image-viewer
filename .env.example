# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# Token used for Gitea operations (release publishing, etc.).
GITEA_TOKEN=

# Directory the file browser opens to when the app is launched without an
# explicit file/folder.
#
#   Development: set it here in `.env`.
#   Production:  set IMAGE_VIEWER_DEFAULT_DIRECTORY as an OS user-level
#                environment variable (on Windows, GUI apps launched from the
#                Start Menu / a shortcut inherit user environment variables).
#
# Leave unset to open the drive list instead.
IMAGE_VIEWER_DEFAULT_DIRECTORY=D:\Pictures
